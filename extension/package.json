{
  "name": "chromabridge-extension",
  "version": "1.0.0",
  "private": true,
  "description": "ChromaBridge browser extension for theme and design token sync",
  "type": "module",
  "scripts": {
    "build": "esbuild src/background.ts src/content.ts --bundle --outdir=dist --format=esm --target=es2022",
    "watch": "esbuild src/background.ts src/content.ts --bundle --outdir=dist --format=esm --target=es2022 --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
